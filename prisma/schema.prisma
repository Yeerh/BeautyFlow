generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int          @id @default(autoincrement())
  name         String?
  username     String?      @unique
  email        String       @unique
  phone        String?
  businessName String?
  businessPhotoUrl String?
  businessAddress String?
  password     String?
  provider     AuthProvider @default(EMAIL)
  role         UserRole     @default(CLIENT)
  isActive     Boolean      @default(true)
  googleId     String?      @unique
  createdById  Int?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  clientBookings  Booking[] @relation("ClientBookings")
  adminBookings   Booking[] @relation("AdminBookings")
  services        Service[] @relation("AdminServices")
  availabilitySlots AvailabilitySlot[] @relation("AdminAvailabilitySlots")
  createdBy    User?        @relation("AdminCreatedUsers", fields: [createdById], references: [id], onDelete: SetNull)
  createdUsers User[]       @relation("AdminCreatedUsers")

  @@index([role])
}

model Booking {
  id            Int           @id @default(autoincrement())
  userId        Int
  adminId       Int?
  serviceId     Int?
  clientName    String
  clientEmail   String
  phone         String
  serviceName   String
  servicePriceCents Int       @default(0)
  servicePrice  String
  scheduledDate String
  scheduledTime String
  scheduledAt   DateTime
  notes         String?
  status        BookingStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  client        User          @relation("ClientBookings", fields: [userId], references: [id], onDelete: Cascade)
  admin         User?         @relation("AdminBookings", fields: [adminId], references: [id], onDelete: SetNull)
  service       Service?      @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@unique([adminId, scheduledDate, scheduledTime])
  @@index([userId, createdAt])
  @@index([adminId, scheduledAt])
  @@index([scheduledAt])
}

model AvailabilitySlot {
  id            Int      @id @default(autoincrement())
  adminId       Int
  scheduledDate String
  scheduledTime String
  scheduledAt   DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  admin         User     @relation("AdminAvailabilitySlots", fields: [adminId], references: [id], onDelete: Cascade)

  @@unique([adminId, scheduledDate, scheduledTime])
  @@index([adminId, scheduledAt])
  @@index([scheduledAt])
}

model Service {
  id          Int       @id @default(autoincrement())
  adminId     Int
  name        String
  description String?
  priceCents  Int
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  admin       User      @relation("AdminServices", fields: [adminId], references: [id], onDelete: Cascade)
  bookings    Booking[]

  @@index([adminId, isActive])
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

enum UserRole {
  CLIENT
  ADMIN
  SUPER_ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}
